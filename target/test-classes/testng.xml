<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="HRIS API Test Suite" verbose="2" parallel="false">

    <listeners>
        <listener class-name="com.juaracoding.ExtentTestNGListener"/>
    </listeners>

    <!-- 1. Authentication - tidak ada dependency -->
    <test name="Authorization">
        <classes>
            <class name="com.juaracoding.Authorization"/>
        </classes>
    </test>

    <!-- 2. Department - tidak ada dependency -->
    <test name="Department">
        <classes>
            <class name="com.juaracoding.Department"/>
        </classes>
    </test>

    <!-- 3. Position - tidak ada dependency -->
    <test name="Position">
        <classes>
            <class name="com.juaracoding.Position"/>
        </classes>
    </test>

    <!-- 4. Permission - tidak ada dependency -->
    <test name="PermissionManagement">
        <classes>
            <class name="com.juaracoding.PermissionManagement"/>
        </classes>
    </test>

    <!-- 5. Role - butuh Permission (dibuat otomatis di @BeforeClass) -->
    <test name="RoleManagement">
        <classes>
            <class name="com.juaracoding.RoleManagement"/>
        </classes>
    </test>

    <!-- 6. User Management - tidak ada dependency -->
    <test name="UserManagement">
        <classes>
            <class name="com.juaracoding.UserManagement"/>
        </classes>
    </test>

    <!-- 7. Employee - butuh Department + Position (dibuat otomatis di @BeforeClass) -->
    <test name="Employee">
        <classes>
            <class name="com.juaracoding.Employee"/>
        </classes>
    </test>

    <!-- 8. User Profile - tidak ada dependency -->
    <test name="UserProfile">
        <classes>
            <class name="com.juaracoding.UserProfile"/>
        </classes>
    </test>

</suite>